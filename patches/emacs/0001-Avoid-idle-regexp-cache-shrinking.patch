From 9da4e2c2c1c136f81cbdfc66ad8a1bb9efefd9f2 Mon Sep 17 00:00:00 2001
From: Kien Nguyen <kien.n.quang@gmail.com>
Date: Thu, 18 Jun 2026 15:21:55 -0700
Subject: [PATCH] Avoid idle regexp-cache shrinking

* src/igc.c (igc_on_idle): Do not shrink the regexp cache
during idle processing.
---
 src/igc.c | 2 --
 1 file changed, 2 deletions(-)

diff --git a/src/igc.c b/src/igc.c
index 1f581ab5256..bf13c76e9a8 100644
--- a/src/igc.c
+++ b/src/igc.c
@@ -4862,8 +4862,6 @@ igc_on_idle (void)
   record_unwind_protect_void (allow_on_idle);
   inhibit_on_idle = true;
 
-  shrink_regexp_cache ();
-
   struct igc_buffer_it buffer_it = make_buffer_it ();
   IGC_WITH_CLOCK (clock, 0.1)
   {
-- 
2.54.0.windows.1

