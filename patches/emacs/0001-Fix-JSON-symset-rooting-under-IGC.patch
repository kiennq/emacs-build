From 4d92b47a2a75a896126bac043dba6bb9cade1fb9 Mon Sep 17 00:00:00 2001
From: Kien Nguyen <kien.n.quang@gmail.com>
Date: Fri, 19 Jun 2026 01:17:08 -0700
Subject: [PATCH] Fix JSON symset rooting under IGC

* src/json.c (make_symset_table): Split the raw symset
header from its exact-rooted entries array under MPS.
(free_symset_table): Free both allocations.
(pop_symset, cleanup_symset_tables, symset_expand): Use it.
---
 src/json.c | 42 ++++++++++++++++++++----------------------
 1 file changed, 20 insertions(+), 22 deletions(-)

diff --git a/src/json.c b/src/json.c
index bdb3f6e5d91..cfb5e073cf5 100644
--- a/src/json.c
+++ b/src/json.c
@@ -129,7 +129,7 @@ json_parse_args (ptrdiff_t nargs, Lisp_Object *args,
      tables if an error occurs.  */
   struct symset_tbl *up;
   /* Table of symbols (2**bits elements), Qunbound where unused.  */
-  Lisp_Object entries[];
+  Lisp_Object *entries;
 };
 
 static inline ptrdiff_t
@@ -144,20 +144,30 @@ make_symset_table (int bits, struct symset_tbl *up)
   int maxbits = min (SIZE_WIDTH - 2 - (word_size < 8 ? 2 : 3), 32);
   if (bits > maxbits)
     memory_full_up ();	/* Will never happen in practice.  */
+  struct symset_tbl *st = xmalloc (sizeof *st);
+  st->up = up;
+  ptrdiff_t size = symset_size (bits);
 #ifdef HAVE_MPS
-  struct symset_tbl *st
-    = igc_xzalloc_ambig (sizeof *st + (sizeof *st->entries << bits),
-			 __func__);
+  st->entries = igc_xalloc_lisp (size, __func__);
 #else
-  struct symset_tbl *st = xmalloc (sizeof *st + (sizeof *st->entries << bits));
+  st->entries = xmalloc (size * sizeof *st->entries);
 #endif
-  st->up = up;
-  ptrdiff_t size = symset_size (bits);
   for (ptrdiff_t i = 0; i < size; i++)
     st->entries[i] = Qunbound;
   return st;
 }
 
+static void
+free_symset_table (struct symset_tbl *st)
+{
+#ifdef HAVE_MPS
+  igc_xfree (st->entries);
+#else
+  xfree (st->entries);
+#endif
+  xfree (st);
+}
+
 /* Create a new symset to use for a new object.  */
 static symset_t
 push_symset (json_out_t *jo)
@@ -173,11 +183,7 @@ push_symset (json_out_t *jo)
 pop_symset (json_out_t *jo, symset_t *ss)
 {
   jo->ss_table = ss->table->up;
-#ifdef HAVE_MPS
-  igc_xfree (ss->table);
-#else
-  xfree (ss->table);
-#endif
+  free_symset_table (ss->table);
 }
 
 /* Remove all heap-allocated symset tables, in case an error occurred.  */
@@ -187,11 +193,7 @@ cleanup_symset_tables (struct symset_tbl *st)
   while (st)
     {
       struct symset_tbl *up = st->up;
-#ifdef HAVE_MPS
-      igc_xfree (st);
-#else
-      xfree (st);
-#endif
+      free_symset_table (st);
       st = up;
     }
 }
@@ -232,11 +234,7 @@ symset_expand (symset_t *ss)
 	  tbl->entries[j] = sym;
 	}
     }
-#ifdef HAVE_MPS
-  igc_xfree (old_table);
-#else
-  xfree (old_table);
-#endif
+  free_symset_table (old_table);
 }
 
 /* If sym is in ss, return false; otherwise add it and return true.
-- 
