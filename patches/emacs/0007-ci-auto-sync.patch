From: Kien Nguyen <kien.n.quang@gmail.com>
Date: Tue, 6 Aug 2024 12:38:45 -0700
Subject: [PATCH 07/24] ci: auto-sync


diff --git a/.github/workflows/sync.yml b/.github/workflows/sync.yml
new file mode 100644
index 00000000000..74cdbcf0a64
--- /dev/null
+++ b/.github/workflows/sync.yml
@@ -0,0 +1,32 @@
+name: Sync with upstream
+
+on:
+  schedule:
+    - cron: "0 */2 * * *"
+  workflow_dispatch:
+  # push:
+  #   branches:
+  #     - feature/native-comp
+
+jobs:
+  sync:
+    name: Sync with upstream
+    runs-on: ubuntu-latest
+    env:
+      upstream_repo: emacs-mirror/emacs
+      upstream_branch: master feature/igc3
+    steps:
+      - name: Clone
+        run: |
+          REPO="https://${GITHUB_ACTOR}:${{ secrets.GITHUB_TOKEN }}@github.com/${GITHUB_REPOSITORY}.git"
+          git clone --filter=tree:0 $REPO .
+      - name: Setup upstream
+        run: |
+          git remote add upstream https://github.com/$upstream_repo.git
+          echo $upstream_branch | xargs -n1 | xargs -I{} git fetch upstream {} --filter=tree:0
+      - name: Sync
+        run: |
+          git config --global user.email "github-actions[bot]"
+          git config --global user.name "github-actions[bot]@users.noreply.github.com"
+          echo $upstream_branch | xargs -n1 | xargs -I{} git merge --no-edit upstream/{}
+          git push origin -f
diff --git a/.gitignore b/.gitignore
index 0123bfbf245..6b4f2f4e4ef 100644
--- a/.gitignore
+++ b/.gitignore
@@ -27,6 +27,7 @@
 !.gitignore
 !.gitlab-ci.yml
 !.mailmap
+!.github/
 
 # Built by 'autogen.sh'.
 /aclocal.m4
