From 63e73974d4eb0a7592197d9bac169f00b12125d6 Mon Sep 17 00:00:00 2001
From: Kien Nguyen <kien.n.quang@gmail.com>
Date: Tue, 24 Sep 2024 01:24:39 -0700
Subject: [PATCH 10/24] package-quickstart-refresh: dont require info, delay
 load instead


diff --git a/lisp/emacs-lisp/package.el b/lisp/emacs-lisp/package.el
index 67474ccf0f7..ad406e66f22 100644
--- a/lisp/emacs-lisp/package.el
+++ b/lisp/emacs-lisp/package.el
@@ -4839,7 +4839,7 @@ package-quickstart-refresh
       (let ((info-dirs
              (mapcar #'package--quickstart-rel (butlast Info-directory-list))))
         (when info-dirs
-          (pp `(progn (require 'info)
+          (pp `(with-eval-after-load 'info
                       (info-initialize)
                       (setq Info-directory-list
                             (append (list . ,info-dirs) Info-directory-list)))
