From 420fcafe211e663e551781ed80472f1d29869443 Mon Sep 17 00:00:00 2001
From: Kien Nguyen <kien.n.quang@gmail.com>
Date: Wed, 13 Sep 2023 19:19:41 +0900
Subject: [PATCH 12/24] Fix empty minor-mode doc string causes error


diff --git a/lisp/emacs-lisp/easy-mmode.el b/lisp/emacs-lisp/easy-mmode.el
index 51f0168d2fb..aa8d4631ef4 100644
--- a/lisp/emacs-lisp/easy-mmode.el
+++ b/lisp/emacs-lisp/easy-mmode.el
@@ -105,7 +105,7 @@ easy-mmode--mode-docstring
       doc
     ;; Compose a new doc string.
     (with-temp-buffer
-      (let ((lines (if doc
+      (let ((lines (if (and doc (not (string= doc "")))
                        (string-lines doc)
                      (list (format "Toggle %s on or off." mode-pretty-name)))))
         ;; Insert the first line from the doc string.
