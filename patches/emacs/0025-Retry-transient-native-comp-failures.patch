From 105f2ef1683ae5efcf9b54508fd6114c8e7b89d8 Mon Sep 17 00:00:00 2001
From: Kien Nguyen <kien.n.quang@gmail.com>
Date: Fri, 19 Jun 2026 21:49:02 -0700
Subject: [PATCH] Retry transient native-comp failures

Retry Emacs batch native-comp invocations a few times.  This lets
Windows CI recover from transient native compiler crashes and avoids
leaving a partial native-lisp tree behind.

* lisp/Makefile.in (EMACS_COMPILE_ATTEMPTS): New variable.
($(THEFILE)c, $(THEFILE)n, .el.elc, %.eln): Retry native
compilation commands.
* src/Makefile.in (EMACS_COMPILE_ATTEMPTS): New variable.
(../native-lisp): Retry native-lisp population after cleaning
partial output.
---
 lisp/Makefile.in | 71 +++++++++++++++++++++++++++++++++++++++---------
 src/Makefile.in  | 36 ++++++++++++++++--------
 2 files changed, 83 insertions(+), 24 deletions(-)

diff --git a/lisp/Makefile.in b/lisp/Makefile.in
index 91255073f86..fab86d89c9e 100644
--- a/lisp/Makefile.in
+++ b/lisp/Makefile.in
@@ -117,6 +117,11 @@ MAIN_FIRST =
 # The actual Emacs command run in the targets below.
 emacs = '$(EMACS)' $(EMACSOPT)
 
+# Number of attempts for each Emacs batch compilation process, including
+# the first try.  This helps Windows CI recover from transient native-compiler
+# subprocess crashes without disabling native compilation.
+EMACS_COMPILE_ATTEMPTS = 3
+
 ## Subdirectories, relative to builddir.
 SUBDIRS = $(sort $(shell find ${srcdir} -type d -print))
 ## Subdirectories, relative to srcdir.
@@ -283,9 +288,17 @@ THEFILE =
 .PHONY: $(THEFILE)c
 $(THEFILE)c:
 ifeq ($(HAVE_NATIVE_COMP),yes)
-	$(AM_V_ELC)$(emacs) $(BYTE_COMPILE_FLAGS) \
-		-l comp -f byte-compile-refresh-preloaded \
-		-f batch-byte+native-compile $(THEFILE)
+	$(AM_V_ELC)attempt=1; while :; do \
+	  $(emacs) $(BYTE_COMPILE_FLAGS) \
+	    -l comp -f byte-compile-refresh-preloaded \
+	    -f batch-byte+native-compile $(THEFILE) && break; \
+	  status=$$?; \
+	  if test $$attempt -ge $(EMACS_COMPILE_ATTEMPTS); then \
+	    exit $$status; \
+	  fi; \
+	  attempt=`expr $$attempt + 1`; \
+	  echo "Retrying Emacs byte/native compilation for $(THEFILE) after exit $$status (attempt $$attempt)" >&2; \
+	done
 else
 	$(AM_V_ELC)$(emacs) $(BYTE_COMPILE_FLAGS) \
 		-l bytecomp -f byte-compile-refresh-preloaded \
@@ -295,9 +308,17 @@ $(THEFILE)c:
 ifeq ($(HAVE_NATIVE_COMP),yes)
 .PHONY: $(THEFILE)n
 $(THEFILE)n:
-	$(AM_V_ELN)$(emacs) $(BYTE_COMPILE_FLAGS) \
-		-l comp -f byte-compile-refresh-preloaded \
-		--eval '(batch-native-compile t)' $(THEFILE)
+	$(AM_V_ELN)attempt=1; while :; do \
+	  $(emacs) $(BYTE_COMPILE_FLAGS) \
+	    -l comp -f byte-compile-refresh-preloaded \
+	    --eval '(batch-native-compile t)' $(THEFILE) && break; \
+	  status=$$?; \
+	  if test $$attempt -ge $(EMACS_COMPILE_ATTEMPTS); then \
+	    exit $$status; \
+	  fi; \
+	  attempt=`expr $$attempt + 1`; \
+	  echo "Retrying Emacs native compilation for $(THEFILE) after exit $$status (attempt $$attempt)" >&2; \
+	done
 endif
 
 # Files MUST be compiled one by one. If we compile several files in a
@@ -323,13 +344,29 @@ .SUFFIXES:
 # which uses it to avoid displaying certain messages which might be
 # irritating/misleading during a bootstrap.
 .el.elc:
-	-$(AM_V_ELC)$(emacs) $(BYTE_COMPILE_FLAGS) \
-	-l comp -f batch-byte-compile $<
+	-$(AM_V_ELC)attempt=1; while :; do \
+	  $(emacs) $(BYTE_COMPILE_FLAGS) \
+	    -l comp -f batch-byte-compile $< && break; \
+	  status=$$?; \
+	  if test $$attempt -ge $(EMACS_COMPILE_ATTEMPTS); then \
+	    exit $$status; \
+	  fi; \
+	  attempt=`expr $$attempt + 1`; \
+	  echo "Retrying Emacs byte compilation for $< after exit $$status (attempt $$attempt)" >&2; \
+	done
 	TZ=UTC0 touch -t 197001010000 $@
 else
 .el.elc:
-	-$(AM_V_ELC)$(emacs) $(BYTE_COMPILE_FLAGS) \
-	-l comp -f batch-byte+native-compile $<
+	-$(AM_V_ELC)attempt=1; while :; do \
+	  $(emacs) $(BYTE_COMPILE_FLAGS) \
+	    -l comp -f batch-byte+native-compile $< && break; \
+	  status=$$?; \
+	  if test $$attempt -ge $(EMACS_COMPILE_ATTEMPTS); then \
+	    exit $$status; \
+	  fi; \
+	  attempt=`expr $$attempt + 1`; \
+	  echo "Retrying Emacs byte/native compilation for $< after exit $$status (attempt $$attempt)" >&2; \
+	done
 endif
 else
 .el.elc:
@@ -444,9 +481,17 @@ .PHONY:
 # compile-eln-aot is called.
 ifeq ($(NATIVE_COMPILATION_AOT),yes)
 %.eln: %.el
-	$(AM_V_ELN)$(emacs) $(BYTE_COMPILE_FLAGS) \
-		-l comp -f byte-compile-refresh-preloaded \
-		--eval '(batch-native-compile t)' $<
+	$(AM_V_ELN)attempt=1; while :; do \
+	  $(emacs) $(BYTE_COMPILE_FLAGS) \
+	    -l comp -f byte-compile-refresh-preloaded \
+	    --eval '(batch-native-compile t)' $< && break; \
+	  status=$$?; \
+	  if test $$attempt -ge $(EMACS_COMPILE_ATTEMPTS); then \
+	    exit $$status; \
+	  fi; \
+	  attempt=`expr $$attempt + 1`; \
+	  echo "Retrying Emacs native compilation for $< after exit $$status (attempt $$attempt)" >&2; \
+	done
 
 compile-eln-targets: $(filter-out $(ELNDONE),$(TARGETS))
 else
diff --git a/src/Makefile.in b/src/Makefile.in
index fa58e1cbd04..12471e4ab20 100644
--- a/src/Makefile.in
+++ b/src/Makefile.in
@@ -945,19 +945,33 @@ elnlisp := $(addprefix ${lispsource}/,${elnlisp}) $(lisp:
 ## compiled and haven't yet been compiled.  ELDONE holds the list
 ## of *.el files that were already native-compiled.
 NATIVE_COMPILATION_AOT = @NATIVE_COMPILATION_AOT@
+EMACS_COMPILE_ATTEMPTS = 3
 ../native-lisp: | $(pdmp)
 	@if test ! -d $@; then \
-	  mkdir $@ && $(MAKE) $(AM_V_NO_PD) $(elnlisp); \
-	  if test $(SYSTEM_TYPE) = cygwin; then \
-	    find $@ -name '*.eln' | rebase -v -O -T -; \
-	  fi; \
-	  LC_ALL=C $(RUN_TEMACS) -batch $(BUILD_DETAILS) -l loadup --temacs=pdump \
-		--bin-dest '$(BIN_DESTDIR)' --eln-dest '$(ELN_DESTDIR)' \
-	  && cp -f emacs$(EXEEXT) bootstrap-emacs$(EXEEXT) \
-	  && cp -f $(pdmp) $(bootstrap_pdmp); \
-	  if test $(NATIVE_COMPILATION_AOT) = yes; then \
-	    $(MAKE) $(AM_V_NO_PD) -C ../lisp compile-eln-aot EMACS="../src/emacs$(EXEEXT)" ELNDONE="$(addprefix %,$(notdir $(elnlisp))))"; \
-	  fi; \
+	  attempt=1; while :; do \
+	    rm -rf $@; \
+	    ( set -e; \
+	      mkdir $@; \
+	      $(MAKE) $(AM_V_NO_PD) $(elnlisp); \
+	      if test $(SYSTEM_TYPE) = cygwin; then \
+	        find $@ -name '*.eln' | rebase -v -O -T -; \
+	      fi; \
+	      LC_ALL=C $(RUN_TEMACS) -batch $(BUILD_DETAILS) -l loadup --temacs=pdump \
+	        --bin-dest '$(BIN_DESTDIR)' --eln-dest '$(ELN_DESTDIR)'; \
+	      cp -f emacs$(EXEEXT) bootstrap-emacs$(EXEEXT); \
+	      cp -f $(pdmp) $(bootstrap_pdmp); \
+	      if test $(NATIVE_COMPILATION_AOT) = yes; then \
+	        $(MAKE) $(AM_V_NO_PD) -C ../lisp compile-eln-aot EMACS="../src/emacs$(EXEEXT)" ELNDONE="$(addprefix %,$(notdir $(elnlisp))))"; \
+	      fi; \
+	    ) && break; \
+	    status=$$?; \
+	    rm -rf $@; \
+	    if test $$attempt -ge $(EMACS_COMPILE_ATTEMPTS); then \
+	      exit $$status; \
+	    fi; \
+	    attempt=`expr $$attempt + 1`; \
+	    echo "Retrying native-lisp population after exit $$status (attempt $$attempt)" >&2; \
+	  done; \
 	fi
 endif
 
-- 
